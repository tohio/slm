# ── AWS / S3 ──────────────────────────────────────────────────────────────────
S3_BUCKET=         # your S3 bucket name
S3_PREFIX=slm/data                  # key prefix inside the bucket
AWS_ACCESS_KEY_ID=...               # IAM user credentials
AWS_SECRET_ACCESS_KEY=...           # IAM user credentials
AWS_DEFAULT_REGION=us-east-1        # must be us-east-1 for Common Crawl
# ── Data ──────────────────────────────────────────────────────────────────────
DATA_DIR=/data/slm/data             # set automatically by setup.sh
RESULTS_DIR=results                 # where training checkpoints are saved
# ── HuggingFace cache ─────────────────────────────────────────────────────────
HF_HOME=/data/slm/hf_cache          # set automatically by setup.sh
HF_DATASETS_CACHE=/data/slm/hf_cache # set automatically by setup.sh
# ── Experiment tracking ───────────────────────────────────────────────────────
WANDB_API_KEY=...                   # from wandb.ai/settings
WANDB_PROJECT=slm                   # W&B project name
# ── HuggingFace Hub ───────────────────────────────────────────────────────────
# HF_TOKEN is used for both model pushes and gated dataset access.
# Required at curation time for: HuggingFaceFW/fineweb, bigcode/the-stack-smol,
# bigcode/the-stack-v2-dedup. Accept Terms of Use on each dataset page first.
HF_TOKEN=...                        # from huggingface.co/settings/tokens
HF_USERNAME=                        # your HF username
# ── Software Heritage Archive ─────────────────────────────────────────────────
# Optional but strongly recommended. the-stack-v2-dedup stores file metadata
# on HuggingFace and fetches actual source code from the Software Heritage
# Archive per-record at curation time. Unauthenticated requests are heavily
# rate-limited; at 1b scale this can multiply stack-v2 fetch time by 10×+.
# Register at https://archive.softwareheritage.org/ to obtain a token.
SWH_AUTH_TOKEN=                     # optional — leave empty to use unauthenticated fetches